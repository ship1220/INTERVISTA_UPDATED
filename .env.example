# ── LLM Configuration ──────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=meta-llama/llama-4-scout-17b-16e-instruct

# ── Learning Resources ─────────────────────────────────────────────────────────
# Optional: YouTube Data API v3 key for higher-quality YouTube results.
# Without this key, the system falls back to YouTube's internal search API
# (no API key needed, but subject to rate limits).
# Get one at: https://console.cloud.google.com/ → Enable "YouTube Data API v3"
YOUTUBE_API_KEY=

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./jobprepmate.db

# ── Application ────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false
ENVIRONMENT=development
